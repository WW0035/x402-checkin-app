pragma solidity ^0.8.20;

contract X402CheckIn {

    mapping(address => uint256) public lastCheckIn;
    mapping(address => uint256) public totalCheckIn;

    event CheckedIn(address user, uint256 time, uint256 total);

    function checkIn() public {
        require(block.timestamp > lastCheckIn[msg.sender] + 1 days, "Already checked today");

        lastCheckIn[msg.sender] = block.timestamp;
        totalCheckIn[msg.sender]++;

        emit CheckedIn(msg.sender, block.timestamp, totalCheckIn[msg.sender]);
    }

    function getMyStats() public view returns (uint256 last, uint256 total) {
        return (lastCheckIn[msg.sender], totalCheckIn[msg.sender]);
    }
}
